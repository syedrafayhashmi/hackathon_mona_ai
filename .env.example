# Google Gemini is required for every workflow run
GEMINI_API_KEY=
# Optional generic override; GEMINI_FAST_MODEL takes precedence when both are set
GEMINI_MODEL=
GEMINI_FAST_MODEL=models/gemini-3.1-flash-lite
GEMINI_IMAGE_MODEL=models/gemini-3.1-flash-image

# Rate-limit resilience and batch concurrency
GEMINI_MAX_RETRIES=4
GEMINI_MAX_CONCURRENCY=5
LOG_LEVEL=INFO

# Frontend uses same-origin /api and /health paths in Docker. Set this only
# when running the web app separately against an external API.
NEXT_PUBLIC_API_URL=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
