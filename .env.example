# Google Gemini (required for all LLM tasks)
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-3.5-flash
GEMINI_FAST_MODEL=models/gemini-3.1-flash-lite
GEMINI_IMAGE_MODEL=models/gemini-3.1-flash-image
